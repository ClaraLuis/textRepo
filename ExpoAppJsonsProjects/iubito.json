{
  "expo": {
    "name": "Iubito",
    "slug": "iubitoslug",
    "scheme": "iubitoappscheme",
    "version": "4.0",
    "icon": "./AppIcons/Iubito/iubito1024.png",
    "notification": {
      "icon": "./AppIcons/Iubito/iubito1024.png"
    },
    "splash": {
      "image": "./AppIcons/Iubito/iubito1024.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.tabex.series.iubitoo",
      "buildNumber":"4",
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./GoogleServicesJSONFiles/iubito-google-services.json",
      "package": "com.tabex.series.iubito",
      "icon": "./AppIcons/Iubito/iubito512.png",
      "versionCode": 4,
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./AppIcons/Iubito/iubito512.png",
        "backgroundColor": "#ffffff"
      }
    },
    "description": "",
    "extra": {
      "iossdk": "48",
      "androidsdk": "48",
      "instapikey": "6373c2b21ed3b",
      "projectsrctype": "subdomain",
      "eas": {
        "projectId": "4e3faaf4-4cf4-4908-b2df-5c3024e75967"
      }
    }
    ,
    "plugins": [
      "expo-tracking-transparency"
    ]
  }
}
