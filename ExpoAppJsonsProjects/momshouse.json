      "package": "com.tabex.series.momshouse",
      "icon": "./AppIcons/momshouse/momshouse512.png",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
