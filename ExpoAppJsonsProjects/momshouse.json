        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./AppIcons/momshouse/momshouse512.png",
        "backgroundColor": "#83d8db"
      }
    },
    "description": "",
    "extra": {
      "instapikey": "64157d64f39ee",
      "projectsrctype": "subdomain",
      "hastrackingpermissions": "yes",
      "iossdk": "48",
      "androidsdk": "48",
      "eas": {
        "projectId": "c9b26a8d-9f10-4191-a1cd-78f9f105d25a"
      }
    },
    "plugins": [
      [
        "expo-tracking-transparency",
