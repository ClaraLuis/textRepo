{
  "expo": {
    "name": "Beesline Egypt",
    "slug": "beeslineslug",
    "scheme": "beeslinescheme",
    "version": "1.0",
    "icon": "./AppIcons/beesline/beesline1024.png",
    "notification": {
      "icon": "./AppIcons/beesline/beesline1024.png"
    },
    "splash": {
      "image": "./AppIcons/beesline/beesline1024.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.tabex.series.beesline",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
