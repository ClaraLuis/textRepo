      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./GoogleServicesJSONFiles/beesline-google-services.json",
      "package": "com.tabex.series.beesline",
      "icon": "./AppIcons/beesline/beesline512.png",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./AppIcons/beesline/beesline512.png",
        "backgroundColor": "#ffffff"
      }
    },
    "description": "",
    "extra": {
      "instapikey": "64478ff1c3c34",
      "projectsrctype": "subdomain",
      "hastrackingpermissions": "yes",
      "iossdk": "48",
      "androidsdk": "48",
      "eas": {
        "projectId": "b1677fbd-6c37-43a6-9e02-77f3819ff2f7"
      }
    },
    "plugins": [
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier email will be used to deliver personalized ads to you."
        }
      ]
    ]
  }
}
