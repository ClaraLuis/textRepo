    },
    "description": "",
    "extra": {
      "iossdk": "48",
      "androidsdk": "48",
      "instapikey": "63cd4fd3349e2",
      "projectsrctype": "subdomain",
      "hastrackingpermissions": "yes",
      "eas": {
